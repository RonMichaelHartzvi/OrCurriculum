rules_version = '2';

// OrCurriculum Firestore rules.
// Every document lives under /users/{uid}/... and is only readable/writable by
// the signed-in user with matching uid. That means even though Firebase web
// config keys are shipped in the client bundle, no one can read/write anyone
// else's data.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
