# Copy this file to .env and fill in the values from your Firebase project.
# Firebase console → Project settings → Your apps → Web app → SDK setup.
# The .env file is git-ignored so these never end up in the public repo.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: comma-separated list of Google emails allowed to sign in.
# Leave empty to allow anyone. When the app is public, set this to the
# emails you want to permit.
VITE_ALLOWED_EMAILS=

# Optional: Google OAuth client ID (Web) for one-way Google Calendar sync.
# Create at Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# client ID → Web application. Authorized JavaScript origin should be your
# Firebase Hosting URL (e.g. https://orcurriculum.web.app) plus http://localhost:5173 for dev.
# Leave empty to disable the "Add to Google Calendar" toggle on planned blocks.
VITE_GOOGLE_CLIENT_ID=
